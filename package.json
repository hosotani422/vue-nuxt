{
  "name": "vue-nuxt",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "npm": "The only package manager is pnpm",
    "yarn": "The only package manager is pnpm",
    "pnpm": ">=9.6.0"
  },
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "ui": "storybook dev -p 6006 -c test/storybook",
    "build:ui": "storybook build -c test/storybook -o .storybook",
    "run:ui": "http-server .storybook --port 6006",
    "lint:format": "prettier --check --config prettier.config.js .",
    "lint:style": "stylelint --config stylelint.config.mjs **/*.css",
    "lint:script": "eslint --config eslint.config.js",
    "fix:format": "prettier --write --config prettier.config.js .",
    "fix:style": "stylelint --fix --config stylelint.config.mjs **/*.css",
    "fix:script": "eslint --fix --config eslint.config.js",
    "test:ut": "vitest --config test/vitest/vitest.config.ts",
    "test:ut.c": "vitest --run --coverage --config test/vitest/vitest.config.ts",
    "test:ui": "test-storybook --config-dir test/storybook --ci --maxWorkers=2",
    "test:ui.ci": "concurrently -k -s first -n \"SB,TEST\" -c \"magenta,blue\" \"pnpm ui\" \"wait-on tcp:6006 && pnpm test:ui\"",
    "test:it": "playwright test --config test/playwright/playwright.config.ts",
    "test:it.testcafe": "testcafe --config-file test/testcafe/.testcaferc.cjs",
    "test:it.cypress": "cypress run --browser chrome --config-file test/cypress/cypress.config.ts",
    "prepare": "husky install && playwright install"
  },
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@pinia/nuxt": "^0.5.2",
    "@playwright/test": "^1.45.3",
    "@storybook/addon-essentials": "^8.2.6",
    "@storybook/test-runner": "^0.19.1",
    "@storybook/vue3-vite": "^8.2.6",
    "@types/lodash": "^4.17.7",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-vue": "^5.1.1",
    "@vitest/coverage-v8": "^2.0.4",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "cypress": "^13.13.1",
    "date-fns": "^3.6.0",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-tailwindcss": "^3.17.4",
    "eslint-plugin-vue": "^9.27.0",
    "happy-dom": "^14.12.3",
    "http-server": "^14.1.1",
    "husky": "^9.1.4",
    "i18next": "^23.12.2",
    "lodash": "^4.17.21",
    "nuxt": "^3.12.4",
    "pinia": "^2.2.0",
    "postcss": "^8.4.40",
    "prettier": "^3.3.3",
    "storybook": "^8.2.6",
    "stylelint": "^16.8.1",
    "stylelint-config-recommended": "^14.0.1",
    "tailwindcss": "^3.4.7",
    "testcafe": "^3.6.2",
    "typescript": "^5.5.4",
    "typescript-eslint": "^7.18.0",
    "unplugin-auto-import": "^0.18.2",
    "unplugin-vue-components": "^0.27.3",
    "vitest": "^2.0.4",
    "wait-on": "^7.2.0",
    "zod": "^3.23.8"
  }
}
